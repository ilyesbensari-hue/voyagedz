# Ignore node_modules
node_modules
npm-debug.log

# Ignore existing database (will be created fresh in container)
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Ignore environment files
.env
.env.local

# Ignore git
.git
.gitignore

# Ignore documentation
*.md
!DOCKER-README.md

# Ignore temporary files
*.log
*.tmp
.DS_Store
Thumbs.db

# Ignore uploads (will use volume)
uploads/*
!uploads/.gitkeep
