# Variables d'environnement - Voyage DZ
# Copier ce fichier en .env et remplir les valeurs

# PostgreSQL (Neon)
DATABASE_URL=postgres://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# JWT Secret (générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=voyage-dz-jwt-secret-change-in-production

# Port local
PORT=3000

# OAuth (optionnel)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# URL de l'app (pour OAuth callbacks)
# APP_URL=https://voyagedz.vercel.app
